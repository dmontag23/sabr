{
  "name": "sabr",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint --max-warnings 0",
    "lint:fix": "expo lint --fix",
    "supabase:type-gen": "supabase gen types typescript --local > src/types/database.types.ts && eslint --fix src/types/database.types.ts",
    "test:unit": "jest",
    "test:e2e": "maestro test .maestro",
    "typecheck": "tsc",
    "prepare": "cd .. && husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.12",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.106.2",
    "aes-js": "^3.1.2",
    "expo": "^56.0.4",
    "expo-constants": "~56.0.15",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.6",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/aes-js": "^3.1.4",
    "@types/jest": "30.0.0",
    "@types/react": "~19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "~30.4.2",
    "jest-expo": "~56.0.4",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3"
  },
  "private": true,
  "packageManager": "pnpm@11.5.0"
}
